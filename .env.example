# Prisma Accelerate connection URL (from Prisma Console)
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION_DAYS="7"

# Server
PORT="8000"
HOST="0.0.0.0"

# CORS - comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000"

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID="414184782324-iijbklnet3vu4083k9kbm6ol1qmdf906.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Must match EXACTLY what is set in Google Cloud Console Authorized Redirect URIs
GOOGLE_REDIRECT_URI="https://api.vcron.cloud/api/auth/google/callback"
# Where to redirect users after successful Google login
FRONTEND_URL="https://www.vcron.cloud"

# Resend Email (optional - for backup email feature)
RESEND_API_KEY=""
SENDER_EMAIL="onboarding@resend.dev"
BACKUP_EMAIL=""
